# =============================================================================
# Pragya-Pravah — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git!
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_PORT=3000

# ---------------------------------------------------------------------------
# Database (Neon Postgres)
# ---------------------------------------------------------------------------
# Option A: Local Docker Postgres (development)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pragyapravah
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/pragyapravah

# Option B: Neon Cloud (production)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Neon API credentials (for branching, local proxy)
NEON_API_KEY=your-neon-api-key
NEON_PROJECT_ID=your-neon-project-id
NEON_PORT=5433

# ---------------------------------------------------------------------------
# gRPC Signal Simulation Service
# ---------------------------------------------------------------------------
GRPC_PORT=50051
GRPC_SERVICE_URL=grpc:50051

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ---------------------------------------------------------------------------
# Demo / E2E Testing
# ---------------------------------------------------------------------------
# Required for Playwright E2E tests (demo-smoke.spec.ts, end-user-simulation.spec.ts)
APP_DEMO_PASSWORD=Password123!
# Optional: used by db seed script for default org code
APP_ORG_CODE=bhopal_vibhag

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443
