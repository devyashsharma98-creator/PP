# ─── Pragya Pravah — Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres pooled connection (used by app at runtime via neon() driver)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection (used by drizzle-kit for migrations — bypasses pooler)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# At least 64 random hex chars. Generate: openssl rand -hex 64
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING"
JWT_EXPIRES_IN="24h"

# Session cookie
SESSION_COOKIE_NAME="pp_session"
SESSION_COOKIE_TTL_SECONDS="86400"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_ORG_CODE="bhopal_vibhag"

# Demo password for all seeded demo accounts (dev/staging only)
# Required by E2E tests (e2e/demo-smoke.spec.ts, e2e/end-user-simulation.spec.ts)
APP_DEMO_PASSWORD="Password123!"

# Feature flags — set to "true" to enable
NEXT_PUBLIC_ENABLE_DEMO_DATA_FALLBACK="false"
NEXT_PUBLIC_ENABLE_DEMO_ROLE_SWITCH="false"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per window per IP (default: 60 req / 1 min)
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW_MS="60000"

# Public-submission rate limit (event registrations, votes)
PUBLIC_RATE_LIMIT_MAX="10"
PUBLIC_RATE_LIMIT_WINDOW_MS="60000"
